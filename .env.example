# HCC Dashboard Configuration
# Copy to .env and fill in values
# IMPORTANT: Escape $ as $$ in this file (Docker Compose requirement)

# Session secret — random string for cookie signing
# Generate with: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-random-string

# Dashboard password — bcrypt hash
# Generate with: docker run --rm node:20-alpine sh -c "cd /tmp && npm init -y && npm install bcryptjs && node -e \"var b=require('bcryptjs');b.hash('YOUR_PASSWORD',12).then(function(h){console.log(h)})\""
# Escape every $ as $$ in the hash
HCC_PASSWORD_HASH=$$2b$$12$$REPLACE_THIS

# Pi-hole (container on router bridge — RPi has forward rules to reach it)
PIHOLE_URL=http://172.17.0.2
PIHOLE_PASSWORD=your-pihole-password

# Prometheus (localhost on RPi when using host networking)
PROMETHEUS_URL=http://127.0.0.1:9090

# RouterOS API
ROUTEROS_HOST=10.10.10.1
ROUTEROS_PORT=8728
ROUTEROS_USER=mktxp_user
ROUTEROS_PASSWORD=your-routeros-password

# Grafana (localhost on RPi when using host networking)
GRAFANA_URL=http://127.0.0.1:3000

# Server instance labels (from node_exporter)
SERVER1_INSTANCE=10.10.10.2:9100
SERVER2_INSTANCE=10.20.20.2:9100

# Polling intervals (seconds)
POLL_PIHOLE=15
POLL_PROMETHEUS=30
POLL_NETWATCH=30
POLL_GRAFANA=60
